PORT=3000
NODE_ENV=production

# Google Sheets Integration
GOOGLE_SHEET_ID=YOUR_GOOGLE_SHEET_ID
GOOGLE_SHEET_RANGE=AI Cold Call!A:Z
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# n8n Integration
N8N_BASE_URL=http://YOUR_SERVER_IP:8080
N8N_WEBHOOK_PATH=/webhook/YOUR_WEBHOOK_ID
N8N_API_KEY=YOUR_N8N_API_KEY
N8N_AUTH_USER=admin
N8N_AUTH_PASSWORD=YOUR_N8N_PASSWORD

# Logging
LOG_LEVEL=info
