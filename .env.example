# Copy this file to .env and configure your settings

# Server Configuration
PORT=3000

# n8n Webhook Configuration
# Replace with your actual n8n webhook URL for manual trigger
N8N_WEBHOOK_URL=http://localhost:5678/webhook/your-webhook-id

# Google Sheets Integration Configuration
# Option 1: API Key (Read-only access, easiest setup)
GOOGLE_API_KEY=your_google_api_key_here

# Option 2: Service Account (Full access, recommended for production)
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"your-project-id"...}

# Google Sheets Configuration
GOOGLE_SHEET_ID=your_google_sheet_id_here
GOOGLE_SHEET_RANGE=Sheet1!A:E

# Instructions for Google Sheets Integration:
# 1. Create a Google Cloud Project at https://console.cloud.google.com
# 2. Enable the Google Sheets API
# 3. Create credentials (API Key or Service Account)
# 4. Get your sheet ID from the URL: 
#    https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
# 5. Make sure your sheet has columns: Name, Phone, Status, Notes, Date
# 6. For API Key: Make your sheet publicly viewable
# 7. For Service Account: Share your sheet with the service account email

# Expected Google Sheets columns:
# Column A: Name (client name)
# Column B: Phone (phone number)
# Column C: Status (Pending, Scheduled, Meeting Booked, Pending Recall)
# Column D: Notes (call notes)
# Column E: Date (last contacted date)
