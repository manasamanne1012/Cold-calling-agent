  },
  "devDependencies": {
    "autocannon": "^7.12.0",
    "chai": "^4.3.10",
    "chai-http": "^4.4.0",
    "eslint": "^8.52.0",
    "mocha": "^10.2.0",
    "nodemon": "^3.0.1",
    "nyc": "^15.1.0",
    "proxyquire": "^2.1.3",
